#!/usr/bin/env bash

if [[ $# -eq 1 ]]; then
  selected=$1
else
  if ! command -v fzf >/dev/null 2>&1; then
    printf 'tmux-sessionizer: fzf is required\n' >&2
    exit 1
  fi

  if [[ -n ${TMUX_SESSIONIZER_DIRS:-} ]]; then
    IFS=: read -r -a search_dirs <<< "$TMUX_SESSIONIZER_DIRS"
  else
    search_dirs=("$HOME/Projects" "$HOME/HomeWork")
  fi

  directories=$(find "${search_dirs[@]}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
  directories+=$'\n'"$HOME/.dotfiles"
  selected=$(printf '%s\n' "$directories" | fzf --tmux)
fi

if [[ -z $selected ]]; then
  exit 0
fi

selected_name=$(basename "$selected" | tr -c '[:alnum:]_-' '_')

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
  # Run project-specific .tmuxrc if it exists (e.g., to set up panes, start dev server)
  if [ -x "$selected/.tmuxrc" ]; then
    tmux send-keys -t "$selected_name" "./.tmuxrc" Enter
  fi
fi

if [[ -z $TMUX ]]; then
  tmux attach -t "$selected_name"
else
  tmux switch-client -t "$selected_name"
fi
